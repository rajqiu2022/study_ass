[Unit]
Description=Study Assistant (Flask + Gunicorn)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/study-assistant
Environment="PATH=/opt/study-assistant/venv/bin"
EnvironmentFile=/opt/study-assistant/.env
ExecStart=/opt/study-assistant/venv/bin/gunicorn -c gunicorn.conf.py run:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
