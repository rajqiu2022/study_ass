[Unit]
Description=Knowledge App (Flask + Gunicorn)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/knowledge-app
Environment="PATH=/opt/knowledge-app/venv/bin"
EnvironmentFile=/opt/knowledge-app/.env
ExecStart=/opt/knowledge-app/venv/bin/gunicorn -c gunicorn.conf.py run:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
